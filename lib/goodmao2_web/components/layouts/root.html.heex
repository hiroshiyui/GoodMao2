<!DOCTYPE html>
<html lang={Goodmao2Web.Locale.html_lang(Gettext.get_locale(Goodmao2Web.Gettext))}>
  <head>
    <meta charset="utf-8" />
    <%!-- viewport-fit=cover lets the installed (standalone) app draw into the notch/home-bar
          area; the shell pads itself back out with the safe-area insets. --%>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="vapid-public-key" content={Goodmao2.Settings.get("vapid_public_key") || ""} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fdf6ef" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#26201c" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='88'>🐾</text></svg>"
    />
    <%!-- Installable web app. iOS ignores the manifest's icons and display mode, so it needs
          the apple-touch-icon and its own meta tags alongside the standard ones. --%>
    <link rel="manifest" href={~p"/manifest.json"} />
    <link rel="apple-touch-icon" href={~p"/images/icons/apple-touch-icon.png"} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="GoodMao" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <.live_title default={brand_name()} suffix={" · " <> brand_name()}>
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script nonce={assigns[:csp_nonce]}>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        // Apply the stored font size before first paint (no flash to the CSS default).
        let fs = Number(localStorage.getItem("phx:font-size")) || 125;
        fs = Math.max(100, Math.min(175, fs));
        document.documentElement.style.fontSize = fs + "%";
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
