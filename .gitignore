# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs. Hand-written
# Markdown design docs under doc/ are tracked; only generated HTML is ignored.
/doc/*
!/doc/*.md
!/doc/adr/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# LifeLog media objects (dev storage_dir; never served, never committed).
/media/

# Ignore package tarball (built via "mix hex.build").
goodmao2-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/
# The service worker is a build artifact (esbuild `service_worker` bundle), regenerated by
# `mix assets.build` / `assets.deploy` — don't commit it.
/priv/static/service_worker.js

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Rust NIF build artifacts (native/<crate>/target and the compiled library Rustler copies
# into priv/native). The source crate under native/ IS tracked; these outputs are not.
/native/*/target/
/priv/native/

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Local, per-developer Claude Code settings.
/.claude/settings.local.json


# Transient agent worktrees
/.claude/worktrees/

# TLS certificates (self-signed dev certs — per-machine, regenerable)
/priv/cert/
