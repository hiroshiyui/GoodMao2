# {{ ansible_managed }}
# GoodMao2 runtime environment — loaded by systemd EnvironmentFile.
# Read at boot by config/runtime.exs. Every var below is required in prod except
# where noted; the app raises on a missing one rather than start half-configured.

# --- server ---
DATABASE_URL=ecto://{{ postgres_db_user }}:{{ postgres_db_password }}@localhost/{{ postgres_db_name }}
SECRET_KEY_BASE={{ secret_key_base }}
PHX_HOST={{ domain }}
PHX_SERVER=true
PORT={{ app_port }}
POOL_SIZE={{ pool_size | default(10) }}

# --- media storage (ADR-0005): writable, backed up, outside any served path ---
MEDIA_STORAGE_DIR={{ media_path }}

# --- mailer: Amazon SES ---
AWS_SES_REGION={{ aws_ses_region }}
AWS_SES_ACCESS_KEY_ID={{ aws_ses_access_key_id }}
AWS_SES_SECRET_ACCESS_KEY={{ aws_ses_secret_access_key }}
MAILER_FROM_EMAIL={{ mailer_from_email | default('no-reply@' + domain) }}
MAILER_FROM_NAME={{ mailer_from_name | default('GoodMao') }}
{% if site_owner_email is defined and site_owner_email %}
# Optional — pins the sole bootstrap admin (ADR-0016).
GOODMAO_SITE_OWNER_EMAIL={{ site_owner_email }}
{% endif %}
